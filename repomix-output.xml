  enabled: true
  interval: 30s
  additionalLabels: {}
  annotations: {}

# Ingress configuration for external access - CORRECTED TO MATCH HOMER
ingress:
  enabled: true
  ingressClassName: traefik
  hosts:
    - host: tempo.milenika.dev
      paths:
        - path: /
          pathType: Prefix
  annotations:
    "kubernetes.io/ingress.class": "traefik"
    "external-dns.alpha.kubernetes.io/target": "eb69efc6-2d0f-424d-a170-53a8c30c65b7.cfargotunnel.com"
    "external-dns.alpha.kubernetes.io/cloudflare-proxied": "true"
    "traefik.ingress.kubernetes.io/router.middlewares": "monitoring-security-headers@kubernetescrd"
    # "traefik.ingress.kubernetes.io/router.tls": "true" <-- REMOVED
  # ADDED: Explicit TLS configuration to match Homer
  tls:
    - secretName: tempo-tls
      hosts:
        - tempo.milenika.dev

# Extra volumes for temporary storage
extraVolumes:
  - name: tmp
    emptyDir: {}

extraVolumeMounts:
  - name: tmp
    mountPath: /tmp

# Basic settings
nodeSelector: {}
tolerations: []
affinity: {}
replicas: 1

# Update strategy
