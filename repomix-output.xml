kind: Kustomization

resources:
  - projects/monitoring-project.yaml
  - monitoring-namespace-app.yaml
  - prometheus-app.yaml
  - loki-app.yaml
  - tempo-app.yaml
  - promtail-app.yaml

# Common labels for all system applications
labels:
  - includeSelectors: true
    pairs:
      app.kubernetes.io/part-of: homelab-gitops
      environment: homelab
