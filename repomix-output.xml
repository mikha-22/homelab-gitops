<file path="06_argocd_install/01_install_argocd.sh">
$!/bin/bash

      
kubectl create namespace argocd


      
helm repo add argo https://argoproj.github.io/argo-helm
helm repo update
helm install argocd argo/argo-cd -n argocd --wait
</file>

<file path="06_argocd_install/argocd-ingress.yaml">
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: argocd-server-ingress
  namespace: argocd
  annotations:
    external-dns.alpha.kubernetes.io/target: "eabb0009-38d6-4998-b247-b687c6a59fae.cfargotunnel.com"
    external-dns.alpha.kubernetes.io/cloudflare-proxied: "true"
    # This annotation is critical for Argo CD
    traefik.ingress.kubernetes.io/service.scheme: https
spec:
  rules:
  - host: argocd.milenika.dev
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: argocd-server
            port:
              number: 443
</file>

<file path="07_gitops_manifests/apps/argocd-ingress-app.yaml">
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: argocd-ingress
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    # Pointing to our own Git repository
    repoURL: 'https://github.com/milenika/homelab.git' # <-- Make sure this is your repo URL
    targetRevision: HEAD
    # CORRECTED PATH: This points to the directory where your argocd-ingress.yaml lives.
    path: 06_argocd_install 
  destination:
    server: 'https://kubernetes.default.svc'
    # The Ingress resource itself will be created in the 'argocd' namespace
    namespace: argocd
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
</file>

