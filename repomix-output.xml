<file path="apps/monitoring/prometheus-stack-values.yaml">
# Prometheus Stack Configuration - PROMETHEUS + GRAFANA ONLY
# Chart Version: 75.9.0
# WITH INGRESS AND ANONYMOUS GRAFANA ACCESS ENABLED

# Global settings
global:
  imageRegistry: ""
  imagePullSecrets: []

# CRDs configuration
crds:
  enabled: true

# Disable AlertManager for simplified homelab setup
alertmanager:
  enabled: false

# Grafana Configuration - WITH ANONYMOUS ACCESS
grafana:
  enabled: true

  # Admin credentials - will use generated password
  adminUser: admin

  # DISABLE the problematic init container
  initChownData:
    enabled: false

  # Persistence
  persistence:
    enabled: true
    type: pvc
    storageClassName: local-path
    size: 10Gi
    accessModes:
      - ReadWriteOnce

  # Resource management
  resources:
    limits:
      cpu: 500m
      memory: 512Mi
    requests:
      cpu: 250m
      memory: 256Mi

  # SIMPLIFIED security context
  securityContext:
    runAsNonRoot: true
    runAsUser: 472
    fsGroup: 472

  # ENABLE INGRESS FOR EXTERNAL ACCESS (MATCH ARGOCD PATTERN)
  ingress:
    enabled: true
    hosts:
      - grafana.milenika.dev
    annotations:
      # Use same pattern as ArgoCD
      "kubernetes.io/ingress.class": "traefik"
      "external-dns.alpha.kubernetes.io/target": "eb69efc6-2d0f-424d-a170-53a8c30c65b7.cfargotunnel.com" # <-- YOUR NEW CNAME
      "external-dns.alpha.kubernetes.io/cloudflare-proxied": "true"
    tls:
      - secretName: grafana-tls
        hosts:
          - grafana.milenika.dev

  # Grafana configuration - WITH ANONYMOUS ACCESS and CORRECT STRUCTURE
  grafana.ini:
    server:
      root_url: "https://grafana.milenika.dev"
      serve_from_sub_path: false

    # ENABLE ANONYMOUS ACCESS FOR DEMOS
    auth.anonymous:
      enabled: true
      org_name: "Main Org."
      org_role: "Viewer"
      hide_version: true

    # Keep login form available for admin access
    auth:
      disable_login_form: false
      disable_signout_menu: false

    security:
      disable_gravatar: true
      cookie_secure: true
      cookie_samesite: "strict"
      strict_transport_security: true
      x_content_type_options: true
      x_xss_protection: true
      allow_embedding: false

    analytics:
      reporting_enabled: false
      check_for_updates: false

    log:
      mode: "console"
      level: "info"

    panels:
      disable_sanitize_html: false

# Prometheus Configuration
prometheus:
  enabled: true

  prometheusSpec:
    # Data retention
    retention: 15d
    retentionSize: 20GB

    # Resource management
    resources:
      limits:
        cpu: 2000m
        memory: 4Gi
      requests:
        cpu: 1000m
        memory: 2Gi

    # SIMPLIFIED security context
    securityContext:
      runAsNonRoot: true
      runAsUser: 1000
      fsGroup: 2000

    # Storage
    storageSpec:
      volumeClaimTemplate:
        spec:
          storageClassName: local-path
          accessModes: ["ReadWriteOnce"]
          resources:
            requests:
              storage: 30Gi

    # Service discovery and monitoring
    serviceMonitorSelectorNilUsesHelmValues: false
    podMonitorSelectorNilUsesHelmValues: false
    ruleSelectorNilUsesHelmValues: false
    serviceMonitorNamespaceSelector: {}
    podMonitorNamespaceSelector: {}
    ruleNamespaceSelector: {}

    # Scrape configuration
    scrapeInterval: 30s
    evaluationInterval: 30s

# Prometheus Operator
prometheusOperator:
  enabled: true

  # Resource management
  resources:
    limits:
      cpu: 200m
      memory: 256Mi
    requests:
      cpu: 100m
      memory: 128Mi

  # SIMPLIFIED security context
  securityContext:
    runAsNonRoot: true
    runAsUser: 65534

# Node Exporter
nodeExporter:
  enabled: true
  resources:
    limits:
      cpu: 200m
      memory: 100Mi
    requests:
      cpu: 100m
      memory: 50Mi

# Kube State Metrics
kubeStateMetrics:
  enabled: true
  resources:
    limits:
      cpu: 100m
      memory: 128Mi
    requests:
      cpu: 50m
      memory: 64Mi

# Default monitoring rules
defaultRules:
  create: true
  rules:
    alertmanager: false
    etcd: true
    configReloaders: true
    general: true
    k8s: true
    kubeApiserverAvailability: true
    kubeApiserverBurnrate: true
    kubeApiserverHistogram: true
    kubeApiserverSlos: true
    kubelet: true
    kubeProxy: true
    kubePrometheusGeneral: true
    kubePrometheusNodeRecording: true
    kubernetesApps: true
    kubernetesResources: true
    kubernetesStorage: true
    kubernetesSystem: true
    network: true
    node: true
    nodeExporterAlerting: true
    nodeExporterRecording: true
    prometheus: true
    prometheusOperator: true

# Cleanup settings
cleanPrometheusOperatorObjectNames: true
</file>

